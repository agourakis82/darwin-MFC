  "about": {
    "title": "关于作者们",
    "subtitle": "创建者和开发者",
    "authors": {
      "demetrios": {
        "name": "Demetrios Agourakis",
        "credentials": "化学工程师 | 律师 | 再生医学与生物材料硕士研究生（PUC-SP）| 医学生",
        "bio": "Demetrios Agourakis是Darwin MFC的创建者，这是一个免费的学术平台，致力于家庭与社区医学。凭借独特的跨学科背景——化学工程师、律师、PUC-SP再生医学与生物材料硕士研究生以及在Faculdade São Leopoldo Mandic实习的医学生——我开发了这个指南，以基于证据的实用工具支持专业人员和学生。",
        "motivation": "促进初级保健的日常咨询，推广全面、有效且人人可及的临床实践。该平台提供超过198种临床状况图谱、互动方案、临床计算器和更新的药物数据库，整合了组织工程、生物材料和初级卫生保健的观点。",
        "credentialsList": {
          "title": "学术背景",
          "items": [
            "化学工程师",
            "律师",
            "再生医学与生物材料硕士研究生（PUC-SP）",
            "医学生（实习：Faculdade São Leopoldo Mandic）"
          ]
        },
        "expertise": {
          "title": "整合领域",
          "items": [
            "家庭与社区医学",
            "组织工程与生物材料",
            "再生医学",
            "初级保健工具开发",
            "开放科学基础设施"
          ]
        }
      },
      "isadora": {
        "name": "Isadora Casagrande Amalcaburio",
        "credentials": "医学生（最后一年），Faculdade São Leopoldo Mandic",
        "bio": "Isadora是Faculdade São Leopoldo Mandic最后一年的医学生，热衷于家庭与社区医学和初级保健。她通过验证临床方案和支持内容开发为Darwin MFC做出贡献。"
      }
    },
