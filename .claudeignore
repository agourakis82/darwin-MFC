# Data files (high impact - prevents accidental large reads)
*.csv
*.jsonl
*.parquet
*.fna
*.fasta
*.fa
*.fq
*.fastq

# Build artifacts
**/target/
**/__pycache__/
*.o
*.so
*.dylib

# Logs & temp
*.log
*.tmp
*.temp
.cache/

# Lock files (large, rarely needed)
Cargo.lock

# Binary/media
*.png
*.jpg
*.jpeg
*.pdf
*.gz
*.zip
*.tar
*.bz2

# Git internals
.git/

# IDE
.vscode/settings.json
.idea/
