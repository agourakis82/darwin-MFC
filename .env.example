# DARWIN-MFC FRONTEND ENVIRONMENT
# =================================
#
# Copy this file to .env.local and fill in the values.
# NEVER commit .env.local to version control!

# =============================================================================
# SUPABASE (Primary Backend)
# =============================================================================
# All CRUD, auth, favorites, notes, progress go through Supabase.
# Get these from https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Optional: Service role key (server-side only, NEVER expose to client)
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# =============================================================================
# LEGACY PHP API (DEPRECATED — removal May 2026, see api-legacy/DEPRECATED.md)
# =============================================================================
# Replaced by Supabase. Only needed if still running the legacy PHP API.
# NEXT_PUBLIC_API_URL=http://localhost:8090

# =============================================================================
# LEGACY KEYCLOAK (DEPRECATED — replaced by Supabase Auth)
# =============================================================================
# NEXT_PUBLIC_KEYCLOAK_URL=http://localhost:8080
# NEXT_PUBLIC_KEYCLOAK_REALM=darwin-mfc
# NEXT_PUBLIC_KEYCLOAK_CLIENT_ID=darwin-mfc-web

# =============================================================================
# MEILISEARCH
# =============================================================================

# Search API URL
NEXT_PUBLIC_SEARCH_URL=http://localhost:7700
NEXT_PUBLIC_SEARCH_API_KEY=

# =============================================================================
# ANALYTICS (Optional)
# =============================================================================

# Privacy-respecting analytics (optional)
# NEXT_PUBLIC_ANALYTICS_ID=

# =============================================================================
# FEATURE FLAGS
# =============================================================================

# Enable/disable features
NEXT_PUBLIC_ENABLE_AUTH=false
NEXT_PUBLIC_ENABLE_COMMUNITY=false
NEXT_PUBLIC_ENABLE_LEARNING=true
NEXT_PUBLIC_ENABLE_PWA=true

# =============================================================================
# DEVELOPMENT
# =============================================================================

# Enable debug mode
NEXT_PUBLIC_DEBUG=false

# =============================================================================
# ELASTICSEARCH (SOTA Search)
# =============================================================================
ELASTICSEARCH_NODE=http://localhost:9200
ELASTICSEARCH_API_KEY=
ELASTICSEARCH_INDEX=darwin-medical-content
ELASTICSEARCH_USERNAME=elastic
ELASTICSEARCH_PASSWORD=changeme

# =============================================================================
# NEO4J (Knowledge Graph)
# =============================================================================
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=darwin-mfc-2025
NEO4J_DATABASE=neo4j

# =============================================================================
# PHARMGKB (Pharmacogenetics)
# =============================================================================
PHARMGKB_API_KEY=your-api-key-here
PHARMGKB_API_URL=https://api.pharmgkb.org/v1
PHARMGKB_CACHE_TTL=3600000

# =============================================================================
# CLINPGX (Pharmacogenetics - formerly PharmGKB)
# =============================================================================
# Option A: Use API (requires API key)
CLINPGX_API_KEY=your-api-key-here
CLINPGX_API_URL=https://api.pharmgkb.org/v1
CLINPGX_USE_DOWNLOADS=false

# Option B: Use downloaded data (free, no API key)
# CLINPGX_USE_DOWNLOADS=true
# CLINPGX_DATA_PATH=./data/clinpgx
CLINPGX_CACHE_TTL=3600000

# =============================================================================
# BIOBERT / ML INFERENCE
# =============================================================================
# BioBERT ONNX model for NER/classification tasks
# Option A: Use local ONNX model
BIOBERT_MODEL_PATH=./models/biobert-pt-onnx
BIOBERT_VOCAB_PATH=./models/biobert-pt-onnx/vocab.txt

# Option B: Use Hugging Face Inference API
# HUGGINGFACE_API_KEY=hf_your_api_key_here
# HUGGINGFACE_MODEL_ID=pucpr-br/biobert-portuguese-clinical

# ML Inference Settings
ML_MAX_SEQUENCE_LENGTH=512
ML_USE_WEBGPU=true
ML_FALLBACK_TO_REGEX=true

# =============================================================================
# EXTERNAL API KEYS (Optional)
# =============================================================================
# PubMed/NCBI for literature search
NCBI_API_KEY=your-ncbi-api-key

# Google OAuth (for Supabase Auth)
# Configure in Supabase Dashboard > Authentication > Providers
# GOOGLE_CLIENT_ID=your-google-client-id
# GOOGLE_CLIENT_SECRET=your-google-client-secret

# =============================================================================
# FHIR / EHR INTEGRATION (Future)
# =============================================================================
# FHIR Server URL (for testing with public sandboxes)
# FHIR_SERVER_URL=https://r4.smarthealthit.org
# FHIR_CLIENT_ID=your-smart-on-fhir-client-id

# =============================================================================
# LOINC DATA
# =============================================================================
# LOINC license agreement required for full dataset
# See: https://loinc.org/get-started/loinc-license/
LOINC_LICENSE_ACCEPTED=false
