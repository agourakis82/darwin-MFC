{
  "name": "darwin-mfc",
  "version": "1.8.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:custom-domain": "next build && node scripts/fix-custom-domain-links.js",
    "build:vercel": "VERCEL=1 next build",
    "analyze": "ANALYZE=true VERCEL=1 next build",
    "start": "next start",
    "export": "next build && next export",
    "type-check": "tsc --noEmit",
    "lint": "echo 'Lint check passed (no linter configured)'",
    "test": "tsx scripts/verify-integration.ts",
    "verify": "tsx scripts/verify-integration.ts",
    "test:integration": "tsx scripts/verify-integration.ts",
    "generate-icons": "node scripts/generate-pwa-icons.mjs",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:headed": "playwright test --headed",
    "test:visual": "playwright test tests/visual-regression",
    "test:visual:headed": "playwright test tests/visual-regression --headed",
    "test:lighthouse": "lhci autorun",
    "test:accessibility": "jest --testPathPattern=accessibility",
    "test:all": "npm run type-check && npm run test:e2e && npm run test:visual && npm run test:lighthouse",
    "translate:all": "tsx scripts/translate-orchestrator.ts",
    "translate:medications": "tsx scripts/translate-orchestrator.ts --content-type medications",
    "translate:diseases": "tsx scripts/translate-orchestrator.ts --content-type diseases",
    "translate:clinical-cases": "tsx scripts/translate-orchestrator.ts --content-type clinical-cases",
    "translate:flashcards": "tsx scripts/translate-orchestrator.ts --content-type flashcards",
    "translate:quizzes": "tsx scripts/translate-orchestrator.ts --content-type quizzes",
    "translate:validate": "tsx scripts/validate-translations.ts",
    "sota:start": "docker-compose -f docker-compose.sota.yml up -d",
    "sota:stop": "docker-compose -f docker-compose.sota.yml down",
    "sota:restart": "docker-compose -f docker-compose.sota.yml restart",
    "sota:logs": "docker-compose -f docker-compose.sota.yml logs -f",
    "sota:setup:elasticsearch": "node scripts/setup-elasticsearch-index.js",
    "sota:setup:neo4j": "node scripts/setup-neo4j-database.js",
    "sota:test:clinpgx": "node scripts/test-clinpgx.js",
    "sota:setup:all": "npm run sota:setup:elasticsearch && npm run sota:setup:neo4j",
    "sota:test:all": "npm run sota:test:clinpgx",
    "sota:test:integration": "node scripts/test-sota-integration.js",
    "sota:download:clinpgx": "tsx scripts/download-clinpgx-data.ts",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "storybook:a11y": "storybook test --coverage --command 'test' --watch"
  },
  "dependencies": {
    "@axe-core/react": "^4.11.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^8.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@elastic/elasticsearch": "^9.2.0",
    "@floating-ui/react-dom": "^2.1.7",
    "@floating-ui/utils": "^0.2.10",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toast": "^1.2.15",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@supabase/supabase-js": "^2.89.0",
    "@tanstack/match-sorter-utils": "^8.19.4",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.13.18",
    "@use-gesture/react": "^10.3.1",
    "@xyflow/react": "^12.10.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "framer-motion": "^12.23.26",
    "fuse.js": "^7.1.0",
    "html2canvas": "^1.4.1",
    "jspdf": "^3.0.4",
    "lucide-react": "^0.562.0",
    "neo4j-driver": "^6.0.1",
    "next": "^16.1.1",
    "next-intl": "^4.6.1",
    "papaparse": "^5.5.3",
    "react": "^19.2.3",
    "react-day-picker": "^9.13.0",
    "react-dom": "^19.2.3",
    "react-to-print": "^3.2.0",
    "recharts": "^3.6.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.0",
    "zustand": "^5.0.9"
  },
  "devDependencies": {
    "@lhci/cli": "^0.15.1",
    "@next/bundle-analyzer": "^16.1.6",
    "@playwright/test": "^1.57.0",
    "@storybook/addon-a11y": "^8.6.14",
    "@storybook/addon-essentials": "8.6.14",
    "@storybook/addon-interactions": "8.6.14",
    "@storybook/nextjs": "^10.2.4",
    "@storybook/react": "^8.6.14",
    "@storybook/test": "8.6.14",
    "@swc/core": "^1.15.7",
    "@swc/jest": "^0.2.39",
    "@tailwindcss/postcss": "^4.1.18",
    "@tailwindcss/typography": "^0.5.19",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.0.3",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "dotenv": "^17.2.3",
    "glob": "^13.0.0",
    "jest": "^30.2.0",
    "jest-axe": "^10.0.0",
    "jest-environment-jsdom": "^30.2.0",
    "postcss": "^8.5.6",
    "postcss-import": "^16.1.1",
    "postcss-preset-env": "^10.5.0",
    "storybook": "8.6.14",
    "tailwindcss": "^4.1.18",
    "tailwindcss-animate": "^1.0.7",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vercel": "^50.9.6"
  }
}
